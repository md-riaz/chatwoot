		"formsnap": "^2.0.1",
		"ky": "^1.14.2",
		"lucide-svelte": "^0.562.0",
		"mode-watcher": "^1.1.0",
		"svelte-i18n": "^4.0.1",
		"svelte-sonner": "^1.0.7",
		"sveltekit-superforms": "^2.29.1",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"zod": "^4.3.4"
	}
}
