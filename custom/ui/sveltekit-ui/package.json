		"mode-watcher": "^0.4.1",
		"svelte-i18n": "^4.0.1",
		"svelte-sonner": "^0.3.28",
		"sveltekit-superforms": "^2.29.1",
		"tailwind-merge": "^2.6.0",
		"tailwind-variants": "^0.2.1",
		"zod": "^3.25.76"
	}
}
