# Chatwoot API Base URL
# Set this to your backend API URL
# Laravel backend typically runs on port 8000
# Original Rails backend runs on port 3000 (for compatibility)
VITE_API_BASE_URL=http://localhost:8000

# WebSocket URL for Laravel Reverb
# For development: ws://localhost:8080/ws (or use the same host as API)
# For production: wss://your-domain.com/ws (with TLS)
# Note: The /ws path is used for WebSocket connections (not /app which is for SPA routes)
VITE_WS_URL=ws://localhost:8080/ws

# Optional: Enable debug mode in development
# VITE_DEBUG=true
