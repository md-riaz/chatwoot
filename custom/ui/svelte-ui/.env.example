# Chatwoot API Base URL
# Set this to your backend API URL
# Laravel backend typically runs on port 8000
# Original Rails backend runs on port 3000 (for compatibility)
VITE_API_BASE_URL=http://localhost:8000

# WebSocket URL for Laravel Reverb
# For development: ws://localhost:8080/app (or use the same host as API)
# For production: wss://your-domain.com/app (with TLS)
# Note: Laravel Reverb uses the /app path by default
VITE_WS_URL=ws://localhost:8080/app

# Optional: Enable debug mode in development
# VITE_DEBUG=true
