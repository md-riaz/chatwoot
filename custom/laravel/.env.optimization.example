# Performance Optimization Environment Variables
# Copy these settings to your .env file for optimal performance

# Application Environment
APP_ENV=production
APP_DEBUG=false

# Cache Configuration (Redis recommended for production)
CACHE_STORE=redis
REDIS_CACHE_CONNECTION=cache
REDIS_SERIALIZER=igbinary
REDIS_COMPRESSION=lz4
REDIS_PERSISTENT=true
REDIS_TCP_KEEPALIVE=1

# Queue Configuration (Redis recommended for production)
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default

# Database Optimization
DB_PERSISTENT=true
DB_POOL_SIZE=10
DB_MAX_CONNECTIONS=100
DB_CONNECTION_TIMEOUT=60
DB_IDLE_TIMEOUT=300

# Configuration Cache Settings
CONFIG_CACHE_ENABLED=true
CONFIG_CACHE_TTL=7200
CONFIG_CACHE_WARM_UP=true
CONFIG_CACHE_PRELOAD=true

# Query Cache Settings
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL=300
CONVERSATION_CACHE_TTL=180
MESSAGE_CACHE_TTL=120

# Model Cache Settings
MODEL_CACHE_ENABLED=true
MODEL_CACHE_TTL=600
MODEL_RELATIONS_CACHE_TTL=300

# Queue Optimization
QUEUE_OPTIMIZATION_ENABLED=true
QUEUE_AUTO_SCALING=true
QUEUE_PRIORITY_ROUTING=true
QUEUE_BATCH_PROCESSING=true

# Queue Workers Configuration
QUEUE_WORKERS_CRITICAL=8
QUEUE_WORKERS_HIGH=6
QUEUE_WORKERS_MEDIUM=4
QUEUE_WORKERS_LOW=2

# Queue Timeouts (seconds)
QUEUE_TIMEOUT_CRITICAL=30
QUEUE_TIMEOUT_HIGH=60
QUEUE_TIMEOUT_MEDIUM=300
QUEUE_TIMEOUT_LOW=900

# Queue Retries
QUEUE_RETRIES_CRITICAL=3
QUEUE_RETRIES_HIGH=3
QUEUE_RETRIES_MEDIUM=2
QUEUE_RETRIES_LOW=1

# Queue Cleanup
FAILED_JOBS_RETENTION_DAYS=7
COMPLETED_JOBS_RETENTION_HOURS=24
QUEUE_AUTO_CLEANUP=true

# Performance Monitoring
PERFORMANCE_MONITORING=true
METRICS_RETENTION_DAYS=30

# Alert Thresholds
ALERT_QUEUE_SIZE=1000
ALERT_FAILURE_RATE=10
ALERT_RESPONSE_TIME=2000
ALERT_MEMORY_USAGE=80

# Production Optimizations
OPCACHE_ENABLED=true
OPCACHE_VALIDATE_TIMESTAMPS=false
OPCACHE_REVALIDATE_FREQ=0
OPCACHE_MAX_FILES=20000
OPCACHE_MEMORY=256

# Laravel Optimizations
LARAVEL_CONFIG_CACHE=true
LARAVEL_ROUTE_CACHE=true
LARAVEL_VIEW_CACHE=true
LARAVEL_EVENT_CACHE=true

# Asset Optimization
ASSET_MINIFICATION=true
ASSET_COMPRESSION=true
CDN_ENABLED=false
ASSET_CACHE_BUSTING=true

# Redis Pool Configuration
REDIS_POOL_MIN=1
REDIS_POOL_MAX=10
REDIS_POOL_WAIT_TIMEOUT=3

# Memory Limits
PHP_MEMORY_LIMIT=512M
QUEUE_MEMORY_LIMIT=256M
CACHE_MEMORY_LIMIT=128M

# Garbage Collection
GC_OPTIMIZATION=true
GC_PROBABILITY=1
GC_DIVISOR=1000

# Database Query Optimization
SLOW_QUERY_THRESHOLD=1000
LOG_SLOW_QUERIES=true
OPTIMIZE_INDEXES=true
ANALYZE_TABLES=true

# Read/Write Database Splitting (if using multiple DB servers)
DB_READ_WRITE_SPLIT=false
DB_READ_CONNECTIONS=2
DB_WRITE_CONNECTIONS=1

# Session Configuration (for better performance)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=chatwoot_session
SESSION_SECURE=true
SESSION_SAME_SITE=lax

# Logging Configuration
LOG_CHANNEL=daily
LOG_LEVEL=warning
LOG_DAYS=7

# Broadcasting (for real-time features)
BROADCAST_DRIVER=redis
PUSHER_APP_CLUSTER=mt1

# Mail Configuration
MAIL_MAILER=smtp
MAIL_QUEUE_CONNECTION=redis_high

# File Storage
FILESYSTEM_DISK=local

# Additional Redis Configuration
REDIS_CLIENT=phpredis
REDIS_PREFIX=chatwoot_
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000

# Horizon Configuration (if using Laravel Horizon)
HORIZON_PREFIX=horizon:
HORIZON_MEMORY_LIMIT=512
HORIZON_TRIM_RECENT=60
HORIZON_TRIM_PENDING=60
HORIZON_TRIM_COMPLETED=60
HORIZON_TRIM_FAILED=10080