# Docker Environment Configuration for ClearLine Laravel
# This file contains Docker-specific environment variables

# Application
APP_NAME="ClearLine"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# Logging
LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Database (PostgreSQL in Docker)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=clearline_production
DB_USERNAME=clearline
DB_PASSWORD=secure_db_password_change_me

# Redis (Redis container)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=secure_redis_password_change_me
REDIS_PORT=6379
REDIS_DB=0

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# Queue
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

# Cache
CACHE_STORE=redis
CACHE_PREFIX=clearline_

# Broadcasting (Laravel Reverb)
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=clearline-app
REVERB_APP_KEY=clearline-key
REVERB_APP_SECRET=clearline-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Mail (Development - using Mailhog)
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@clearline.local"
MAIL_FROM_NAME="${APP_NAME}"

# File Storage
FILESYSTEM_DISK=local
MEDIA_DISK=public

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:8000,127.0.0.1:8000

# Docker-specific ports
APP_PORT=8000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
MAILHOG_WEB_PORT=8025
MAILHOG_SMTP_PORT=1025
PGADMIN_PORT=8080
PGADMIN_EMAIL=admin@clearline.local
PGADMIN_PASSWORD=admin
REDIS_COMMANDER_PORT=8081

# Security
BCRYPT_ROUNDS=12
HASH_VERIFY=true

# Rate Limiting
THROTTLE_REQUESTS_PER_MINUTE=60
API_RATE_LIMIT=1000

# Features
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET=true

# Third-party Integrations (Optional - add your keys)
# OPENAI_API_KEY=your-openai-key
# SLACK_CLIENT_ID=your-slack-client-id
# SLACK_CLIENT_SECRET=your-slack-client-secret
# LINEAR_API_KEY=your-linear-api-key
# SHOPIFY_API_KEY=your-shopify-api-key
# SHOPIFY_API_SECRET=your-shopify-api-secret

# Channel Configurations (Optional - add your keys)
# WHATSAPP_CLOUD_API_ACCESS_TOKEN=your-whatsapp-token
# FACEBOOK_APP_ID=your-facebook-app-id
# FACEBOOK_APP_SECRET=your-facebook-app-secret
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TWITTER_API_KEY=your-twitter-api-key
# TWITTER_API_SECRET=your-twitter-api-secret
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Email Configuration
EMAIL_BRAND_NAME="ClearLine Support"
EMAIL_BRAND_URL=http://localhost:8000
EMAIL_SUPPORT_EMAIL=support@clearline.local
EMAIL_TEMPLATE_CACHE_TTL=3600
EMAIL_LIQUID_ENABLED=true
EMAIL_FALLBACK_LOCALE=en

# Performance
OPCACHE_ENABLE=1
OPCACHE_MEMORY_CONSUMPTION=256
OPCACHE_MAX_ACCELERATED_FILES=4000

# Horizon Configuration
HORIZON_BALANCE=auto
HORIZON_MAX_PROCESSES=10
HORIZON_TRIES=3
HORIZON_TIMEOUT=300
HORIZON_MEMORY=512