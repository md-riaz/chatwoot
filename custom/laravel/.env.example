APP_NAME="ClearLine"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# CORS Configuration for API-only setup with separate frontend
# Use * for all origins (development only) or specify comma-separated origins
# For production, ALWAYS specify exact origins for security
# Example: http://localhost:3000,https://yourdomain.com,https://yourapp.netlify.app
# Frontend deployment error fix: Add your frontend domain (e.g., https://clearlines.netlify.app)
# Add both API domain and frontend domain for proper CORS:
# https://clearline.mdriaz.com.bd,https://clearlines.netlify.app
CORS_ALLOWED_ORIGINS=*

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration - PostgreSQL Primary
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=clearline_development
DB_USERNAME=postgres
DB_PASSWORD=

# Session - Use Redis for API scalability
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting - Laravel Reverb for WebSocket
BROADCAST_CONNECTION=reverb

# Filesystem - Local storage for attachments/media
FILESYSTEM_DISK=local
MEDIA_DISK=local

# Queue - Redis for background jobs
QUEUE_CONNECTION=redis

# Cache - Redis for performance
CACHE_STORE=redis
# CACHE_PREFIX=

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 Configuration (Optional - for cloud storage if needed)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Laravel Reverb WebSocket Configuration
# Generate unique credentials for your application
# Use: php artisan reverb:install to generate these automatically
REVERB_APP_ID=123456
REVERB_APP_KEY=your-app-key-here
REVERB_APP_SECRET=your-app-secret-here
# Server binding - use 0.0.0.0 for all interfaces, 127.0.0.1 for localhost only
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
# For production with SSL/TLS:
# REVERB_SCHEME=https
# REVERB_PORT=443

# Laravel Sanctum - API Authentication
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# Horizon - Queue Dashboard
HORIZON_DOMAIN=
HORIZON_PATH=horizon
HORIZON_USE=default
HORIZON_QUEUE=redis
HORIZON_MAX_PROCESSES=3
HORIZON_PREFIX=clearline_horizon:

# Push Notifications
PUSH_RELAY_URL=
FIREBASE_PROJECT_ID=
# Provide the path to a Firebase service account JSON file or the raw JSON string
FIREBASE_CREDENTIALS=

# Account Seeding Configuration
# Controls whether demo data seeding is allowed for accounts
# Automatically disabled in production for security
# Set to true to enable seeding in development/testing environments
ENABLE_ACCOUNT_SEEDING=true
