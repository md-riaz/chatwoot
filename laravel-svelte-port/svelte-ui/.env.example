# Chatwoot API Base URL
# Set this to your backend API URL
# Laravel backend typically runs on port 8000
# Original Rails backend runs on port 3000 (for compatibility)
VITE_API_BASE_URL=http://127.0.0.1:8000

# WebSocket URL for Laravel Reverb
# Format: ws://host:port for direct connection or ws://host/ws for proxied
# Development: ws://127.0.0.1:8080 (direct connection, Pusher.js adds /app/{key} automatically)
# Production: wss://your-domain.com/ws (proxied through Nginx)
# Note: For direct connections, don't include /app/{key} in URL - Pusher.js handles this
VITE_WS_URL=ws://127.0.0.1:8080

# Optional: Enable debug mode in development
# VITE_DEBUG=true
